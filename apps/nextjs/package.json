{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @codeqr/analytics... build && next build",
    "build:script": "pnpm --filter @codeqr/analytics-script build && rm -rf public/analytics && mkdir -p public/analytics && cp -R ../../packages/script/dist/analytics/. public/analytics/",
    "dev": "next dev",
    "lint": "next lint",
    "start": "next start",
    "test": "playwright test",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui"
  },
  "dependencies": {
    "@codeqr/analytics": "workspace:*",
    "next": "15.5.18",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.19",
    "dotenv": "^16.5.0",
    "eslint": "^8",
    "eslint-config-next": "15.5.15",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5"
  }
}